# =============================================================================
# WellFit EMR — Variables de entorno
# =============================================================================
# Copia este archivo a apps/server/.env y apps/web/.env (o usa uno por app).
# Toda nueva variable debe reflejarse aquí y en @wellfit-emr/env.
# =============================================================================

# ---------------------------------------------------------------------------
# Servidor (apps/server/.env)
# ---------------------------------------------------------------------------

# Better Auth — secreto de firma de tokens (mínimo 32 caracteres)
BETTER_AUTH_SECRET=changeme_32chars_minimum

# URL pública del servidor de autenticación
BETTER_AUTH_URL=http://localhost:3004

# Origen permitido para CORS (frontend)
CORS_ORIGIN=http://localhost:3001

# SQLite — ruta relativa desde packages/api/
DATABASE_URL=file:../../local.db

# Proveedores de IA (al menos uno requerido para el agente médico)
GOOGLE_GENERATIVE_AI_API_KEY=your_google_ai_key
FIREWORKS_API_KEY=your_fireworks_key

# RustFS / S3 local
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY_ID=rustfsadmin
S3_SECRET_ACCESS_KEY=rustfsadmin
S3_BUCKET=wellfit-emr
S3_REGION=us-east-1

# ---------------------------------------------------------------------------
# Cliente web (apps/web/.env)
# ---------------------------------------------------------------------------

# URL del servidor de API (usada por Vite en runtime)
VITE_SERVER_URL=http://localhost:3004
